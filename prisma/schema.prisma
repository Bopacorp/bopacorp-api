generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TestItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
