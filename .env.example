# =============================================================================
# BOPADIGITAL API - Environment Variables Template
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE - Supabase PostgreSQL
# -----------------------------------------------------------------------------
# Get your connection string from Supabase Dashboard > Settings > Database
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# Direct connection (for migrations/admin operations)
# Sometimes needed for Prisma migrations on Supabase
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# AUTHENTICATION - JWT
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# FILE UPLOADS
# -----------------------------------------------------------------------------
# Max file size in bytes (50MB = 52428800)
MAX_FILE_SIZE=52428800

# Storage: local (development) or supabase (production)
UPLOAD_STORAGE=local
UPLOAD_DIR="./uploads"

# Supabase Storage (for production file uploads)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_BUCKET="documents"

# -----------------------------------------------------------------------------
# EMAIL (Optional - for notifications)
# -----------------------------------------------------------------------------
# SMTP configuration for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
FROM_EMAIL="noreply@bopacorp.com"
FROM_NAME="BOPADIGITAL"

# -----------------------------------------------------------------------------
# LOGGING - Pino
# -----------------------------------------------------------------------------
# Log levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug

# Enable pretty printing in development (true/false)
LOG_PRETTY=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features during development
ENABLE_SWAGGER=true
ENABLE_RATE_LIMITING=true

# =============================================================================
# DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION
# =============================================================================

# Enable detailed error messages (development only)
DETAILED_ERRORS=true

# Prisma query logging (development only)
PRISMA_LOG_QUERIES=true
