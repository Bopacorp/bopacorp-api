# BOPADIGITAL API - Environment Variables
# Copy this file to .env and fill in your actual values

# Server
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/bopacorp"
DIRECT_URL="postgresql://postgres:password@localhost:5432/bopacorp"

# JWT Authentication (min 32 chars: openssl rand -base64 32)
JWT_SECRET="change-this-in-production-min-32-chars-long-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Supabase Storage (S3-compatible)
S3_REGION=""
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_S3_ENDPOINT="https://<project>.supabase.co/storage/v1/s3"
SUPABASE_S3_ACCESS_KEY_ID="<access-key-id>"
SUPABASE_S3_SECRET_ACCESS_KEY="<secret-access-key>"
SUPABASE_STORAGE_BUCKET="resumes"
